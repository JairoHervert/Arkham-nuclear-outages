# Backend API Base URL
# The URL where your FastAPI backend is running
# For local development: http://127.0.0.1:8000
# For production: https://your-api-domain.com
VITE_API_BASE_URL=http://127.0.0.1:8000

# Read-only API Key
# Use this key for general data queries (GET /data)
# Must match NUCLEAR_OUTAGES_READ_API_KEY from backend .env
VITE_NUCLEAR_OUTAGES_READ_API_KEY=YOUR_READ_API_KEY

# Admin API Key
# Use this key for administrative actions like data refresh (POST /refresh)
# Must match NUCLEAR_OUTAGES_ADMIN_API_KEY from backend .env
VITE_NUCLEAR_OUTAGES_ADMIN_API_KEY=YOUR_ADMIN_API_KEY